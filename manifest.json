{
  "manifest_version": 3,
  "name": "Scheduled Website Blocker",
  "description": "Blocks websites by schedule and tracks daily website screen time.",
  "version": "0.6.0",
  "minimum_chrome_version": "101",
  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Scheduled Website Blocker",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
